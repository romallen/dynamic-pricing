# Type signature for the main service class.
# run fetches a rate (from cache or the external API) and sets result.
# Callers check valid? to know whether result is usable or errors has details.
module Api
  module V1
    class PricingService < BaseService
      # ActiveSupport::Duration — typed as untyped to keep `rbs validate`
      # self-contained without pulling in the full Rails type collection.
      CACHE_TTL: untyped

      def initialize: (period: String, hotel: String, room: String) -> void
      def run: () -> void

      private

      def serve_from_cache?: (String cache_key) -> bool
      def call_api: (String cache_key) -> untyped?
      def handle_success: (untyped rate, String cache_key) -> void
      def extract_rate: (Hash[String, untyped] parsed_rate) -> String?
      def store_in_cache: (String cache_key) -> void
      def handle_error: (untyped rate, String cache_key) -> void
      def parse_json_object: (String body) -> Hash[String, untyped]?
      def log_event: (Symbol level, String event, **untyped fields) -> void
    end
  end
end
